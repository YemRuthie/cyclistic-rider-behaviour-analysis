                    <format attr='margin' value='4' />
                    <format attr='padding' value='0' />
                  </zone-style>
                </zone>
                <zone fixed-size='280' h='46121' id='10' is-fixed='true' name='Sheet 3' w='34578' x='483' y='6815'>
                  <zone-style>
                    <format attr='border-color' value='#000000' />
                    <format attr='border-style' value='none' />
                    <format attr='border-width' value='0' />
                    <format attr='margin' value='4' />
                    <format attr='padding' value='0' />
                  </zone-style>
                </zone>
                <zone fixed-size='280' h='46121' id='3' is-fixed='true' name='Average Ride Length by Rider Type' w='26736' x='35061' y='6815'>
                  <zone-style>
                    <format attr='border-color' value='#000000' />
                    <format attr='border-style' value='none' />
                    <format attr='border-width' value='0' />
                    <format attr='margin' value='4' />
                    <format attr='padding' value='0' />
                  </zone-style>
                </zone>
                <zone forceUpdate='true' h='46123' id='16' type-v2='text' w='28064' x='61797' y='6815'>
                  <formatted-text>
                    <run bold='true' fontcolor='#000000' fontsize='14'>Key Insights</run>
                    <run>Æ&#10;&#10;</run>
                    <run fontcolor='#000000' fontsize='11'>• Casual riders take rides 58% longer than members.</run>
                    <run>Æ&#10;&#10;</run>
                    <run fontcolor='#000000' fontsize='11'>• Casual riders show strong weekend usage patterns.</run>
                    <run>Æ&#10;&#10;</run>
                    <run fontcolor='#000000' fontsize='11'>• Members exhibit commuter behaviour, with pronounced ride peaks at 8 AM and 5 PM.</run>
                    <run>Æ&#10;&#10;</run>
                    <run fontcolor='#000000' fontsize='11'>• Both rider groups strongly prefer electric bikes.</run>
                    <run>Æ&#10;&#10;</run>
                    <run fontcolor='#000000' fontsize='11'>• Casual riders appear to use Cyclistic primarily for leisure, while members use it as part of their regular transportation routine.</run>
                  </formatted-text>
                  <zone-style>
                    <format attr='border-color' value='#000000' />
                    <format attr='border-style' value='none' />
                    <format attr='border-width' value='0' />
                    <format attr='margin' value='4' />
                    <format attr='padding' value='0' />
                  </zone-style>
                </zone>
                <zone fixed-size='280' h='46124' id='5' is-fixed='true' name='Sheet 2' w='34578' x='483' y='52936'>
                  <zone-style>
                    <format attr='border-color' value='#000000' />
                    <format attr='border-style' value='none' />
                    <format attr='border-width' value='0' />
                    <format attr='margin' value='4' />
                    <format attr='padding' value='0' />
                  </zone-style>
                </zone>
                <zone h='8461' id='9' name='Sheet 2' pane-specification-id='0' param='[federated.122llcd0gxpn9u1dfyglr0lxk0qa].[none:member_casual:nk]' type-v2='color' w='9656' x='89861' y='6815'>
                  <zone-style>
                    <format attr='border-color' value='#000000' />
